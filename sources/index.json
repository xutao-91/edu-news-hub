  "crawler_rules": {
    "edweek": {
      "date_selectors": [
        "span.m-article-title__author",
        "meta[property='article:published_time']"
      ],
      "date_pattern": "— ([A-Za-z]+ \\d{1,2}, \\d{4})",
      "title_selector": "h1.m-article-title__text",
      "content_selector": "div.m-article-content"
    },
    "chronicle": {
      "date_selectors": [
        "time.c-article-header__date",
        "meta[property='article:published_time']"
      ],
      "title_selector": "h1.c-article-header__title",
      "content_selector": "div.c-article-body"
    },
    "wordpress": {
      "date_selectors": [
        "meta[property='article:published_time']",
        "time.entry-date",
        "span.posted-on time"
      ],
      "title_selector": "h1.entry-title, h1.article-title",
      "content_selector": "div.entry-content, article"
    },
    "generic": {
      "date_selectors": [
        "meta[property='article:published_time']",
        "time",
        "span.date",
        "div.date"
      ],
      "title_selector": "h1",
      "content_selector": "article, div.content, div.entry-content"
    },
    "cato": {
      "date_selectors": [
        "span.date-time__date--default",
        "meta[property=\"article:published_time\"]"
      ],
      "date_pattern": "([A-Za-z]+ \\d{1,2}, \\d{4})",
      "title_selector": "h1.h2, h1[property=\"headline\"]",
      "content_selector": "div.blog-page__content"
    },
    "edgov": {
      "date_selectors": [
        "time[datetime]",
        "div.field--name-published-at time",
        "meta[property=\"article:published_time\"]"
      ],
      "date_attribute": "datetime",
      "date_pattern": "(\\d{4}-\\d{2}-\\d{2})",
      "title_selector": "h1, h1.ed-node-title",
      "content_selector": "div.field--name-body, div.ed-node-content"
    },
    "pew": {
      "date_selectors": [
        "div.page-metadata__items span.page-metadata__item.text-body-xs",
        "meta[property=\"article:published_time\"]"
      ],
      "date_index": 1,
      "date_pattern": "([A-Za-z]+ \\d{1,2}, \\d{4})",
      "title_selector": "h1, h1.article-title",
      "content_selector": "div.article-content, div.main-content"
    },
    "iowa": {
      "date_selectors": [
        "div.field--name-field-news__display-date time",
        "time.datetime",
        "meta[property=\"article:published_time\"]"
      ],
      "date_attribute": "datetime",
      "date_pattern": "(\\d{4}-\\d{2}-\\d{2})",
      "title_selector": "h1, h1.page-title",
      "content_selector": "div.field--name-body, div.node__content"
    }
  }
}